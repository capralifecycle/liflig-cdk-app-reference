{
  "name": "infrastructure",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "scripts": {
    "cdk": "cdk",
    "fetch-variables": "fetch-pipeline-variables",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format --write",
    "snapshots": "rm -rf cdk.out __snapshots__ && IS_SNAPSHOT=true cdk synth && cdk-create-snapshots",
    "upgrade-dependencies": "ncu --upgrade --install always --format group --reject @types/node"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/node": "24.12.2",
    "aws-cdk": "2.1120.0",
    "npm-check-updates": "22.0.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@capraconsulting/webapp-deploy-lambda": "2.5.96",
    "@liflig/cdk": "3.26.8",
    "aws-cdk-lib": "2.252.0",
    "constructs": "10.6.0"
  }
}
