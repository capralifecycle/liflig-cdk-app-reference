{
  "name": "infrastructure",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "scripts": {
    "cdk": "cdk",
    "fetch-variables": "fetch-pipeline-variables",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format --write",
    "snapshots": "rm -rf cdk.out __snapshots__ && IS_SNAPSHOT=true cdk synth && cdk-create-snapshots",
    "upgrade-dependencies": "ncu --upgrade --install always --format group --reject @types/node"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "24.13.3",
    "aws-cdk": "2.1129.0",
    "npm-check-updates": "22.2.9",
    "tsx": "4.23.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@capraconsulting/webapp-deploy-lambda": "2.5.133",
    "@liflig/cdk": "3.27.27",
    "aws-cdk-lib": "2.261.0",
    "constructs": "10.6.0"
  }
}
